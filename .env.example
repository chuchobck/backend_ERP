# ── Base de datos ──────────────────────────────────────────
# Neon PostgreSQL (o local PG16)
DATABASE_URL="postgresql://USER:PASSWORD@HOST/comercial?schema=comercial"

# ── JWT ───────────────────────────────────────────────────
JWT_SECRET="cambiar-esto-a-algo-seguro-de-64-chars-minimo"
JWT_EXPIRES_IN="8h"

# ── Server ────────────────────────────────────────────────
PORT=3001
NODE_ENV=development

# ── CORS ──────────────────────────────────────────────────
CORS_ORIGIN="http://localhost:5173"
