  fac_iva         Decimal          @default(0.00) @db.Decimal(14, 2)
  fac_ice         Decimal          @default(0.00) @db.Decimal(14, 2)
  fac_total       Decimal?         @default(dbgenerated("(((fac_subtotal - fac_descuento) + fac_iva) + fac_ice)")) @db.Decimal(14, 2)
