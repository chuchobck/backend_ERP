generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["multiSchema"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  schemas  = ["comercial"]
}

model provincias {
  id_provincia    String     @id(map: "pk_provincias") @db.Char(3)
  prv_descripcion String     @db.VarChar(30)
  ciudades        ciudades[]

  @@schema("comercial")
}

model ciudades {
  id_ciudad       String        @id(map: "pk_ciudades") @db.Char(3)
  ciu_descripcion String        @db.VarChar(30)
  id_provincia    String        @db.Char(3)
  provincia       provincias    @relation(fields: [id_provincia], references: [id_provincia], map: "fk_ciu_prv")
  clientes        clientes[]
  proveedores     proveedores[]

  @@schema("comercial")
}

model unidades_medidas {
  id_unidad_medida      String                  @id(map: "pk_unidades_medidas") @db.Char(3)
  um_descripcion        String                  @db.VarChar(20)
  ajuste_inv_det        ajuste_inv_det[]
  devolucion_det        devolucion_det[]
  entrega_det           entrega_det[]
  factura_det           factura_det[]
  inventario_fisico_det inventario_fisico_det[]
  movimientos_inv       movimientos_inv[]
  productos_compra      productos[]             @relation("um_compra")
  productos_venta       productos[]             @relation("um_venta")

  @@schema("comercial")
}

model departamentos {
  id_departamento                                                 String            @id(map: "pk_departamentos") @db.Char(3)
  dep_descripcion                                                 String            @db.VarChar(30)
  dep_presupuesto                                                 Decimal           @default(0.00) @db.Decimal(10, 2)
  centros_costo                                                   centros_costo[]
  compras                                                         compras[]
  empleados                                                       empleados[]
  historial_cargo_historial_cargo_id_dpto_anteriorTodepartamentos historial_cargo[] @relation("historial_cargo_id_dpto_anteriorTodepartamentos")
  historial_cargo_historial_cargo_id_dpto_nuevoTodepartamentos    historial_cargo[] @relation("historial_cargo_id_dpto_nuevoTodepartamentos")

  @@schema("comercial")
}

model roles {
  id_rol             String            @id(map: "pk_roles") @db.Char(3)
  rol_descripcion    String            @db.VarChar(30)
  empleados          empleados[]
  historial_anterior historial_cargo[] @relation("rol_anterior")
  historial_nuevo    historial_cargo[] @relation("rol_nuevo")

  @@schema("comercial")
}

model categorias {
  id_categoria    String      @id(map: "pk_categorias") @db.Char(3)
  cat_descripcion String      @db.VarChar(30)
  productos       productos[]

  @@schema("comercial")
}

model th_descuentos {
  id_descuento    String    @id(map: "pk_th_descuentos") @db.Char(3)
  des_descripcion String    @db.VarChar(30)
  des_valor       Decimal   @default(0.00) @db.Decimal(7, 2)
  compras         compras[]

  @@schema("comercial")
}

model th_bonificaciones {
  id_bonificacion String  @id(map: "pk_th_bonificaciones") @db.Char(3)
  bon_descripcion String  @db.VarChar(30)
  bon_valor       Decimal @default(0.00) @db.Decimal(7, 2)

  @@schema("comercial")
}

model productos {
  id_producto           String                  @id(map: "pk_productos") @db.Char(7)
  id_categoria          String                  @db.Char(3)
  pro_nombre            String                  @unique(map: "uq_pro_nombre") @db.VarChar(40)
  pro_descripcion       String?                 @db.VarChar(100)
  fk_pro_um_compra      String                  @db.Char(3)
  fk_pro_um_venta       String                  @db.Char(3)
  pro_valor_compra      Decimal                 @default(0.00) @db.Decimal(10, 2)
  pro_precio_venta      Decimal                 @default(0.00) @db.Decimal(10, 2)
  pro_saldo_inicial     Int                     @default(0)
  pro_qty_ingresos      Int                     @default(0)
  pro_qty_egresos       Int                     @default(0)
  pro_qty_ajustes       Int                     @default(0)
  pro_saldo_final       Int?                    @default(dbgenerated("(((pro_saldo_inicial + pro_qty_ingresos) - pro_qty_egresos) + pro_qty_ajustes)"))
  estado_prod           String                  @default("ACT") @db.Char(3)
  ajuste_inv_det        ajuste_inv_det[]
  devolucion_det        devolucion_det[]
  entrega_det           entrega_det[]
  factor_conversion     factor_conversion?
  factura_det           factura_det[]
  inventario_fisico_det inventario_fisico_det[]
  movimientos_inv       movimientos_inv[]
  categoria             categorias              @relation(fields: [id_categoria], references: [id_categoria], map: "fk_pro_categoria")
  um_compra             unidades_medidas        @relation("um_compra", fields: [fk_pro_um_compra], references: [id_unidad_medida], map: "fk_pro_um_compra")
  um_venta              unidades_medidas        @relation("um_venta", fields: [fk_pro_um_venta], references: [id_unidad_medida], map: "fk_pro_um_venta")
  proveedor_producto    proveedor_producto[]
  proxoc                proxoc[]
  proxrec               proxrec[]
  stock_bodega          stock_bodega[]
  ubicacion_percha      ubicacion_percha[]

  @@schema("comercial")
}

model empleados {
  id_empleado            String                  @id(map: "pk_empleados") @db.Char(7)
  emp_nombres            String                  @db.VarChar(40)
  emp_apellidos          String                  @db.VarChar(40)
  emp_cedula             String                  @unique(map: "uq_emp_cedula") @db.VarChar(10)
  id_departamento        String                  @db.Char(3)
  id_rol                 String                  @db.Char(3)
  estado_emp             String                  @default("ACT") @db.Char(3)
  emp_segundo_apellido   String?                 @db.VarChar(40)
  emp_segundo_nombre     String?                 @db.VarChar(40)
  emp_fecha_nacimiento   DateTime?               @db.Date
  emp_sexo               String?                 @db.Char(1)
  emp_email              String?                 @db.VarChar(80)
  emp_telefono           String?                 @db.VarChar(10)
  emp_celular            String?                 @db.VarChar(10)
  emp_direccion          String?                 @db.VarChar(120)
  emp_tipo_sangre        String?                 @db.Char(3)
  emp_sueldo             Decimal                 @default(0.00) @db.Decimal(14, 2)
  emp_banco              String?                 @db.VarChar(50)
  emp_tipo_cuenta        String?                 @db.Char(3)
  emp_cuenta_bancaria    String?                 @db.VarChar(25)
  emp_foto               String?                 @db.VarChar(200)
  emp_fecha_ingreso      DateTime?               @db.Date
  id_tipo_contrato       String?                 @db.Char(3)
  id_jefe                String?                 @db.Char(7)
  ajustes_aprobados      ajustes_inv[]           @relation("aji_aprobador")
  ajustes_creados        ajustes_inv[]           @relation("aji_empleado")
  asistencias            asistencias[]
  bodegas_responsable    bodegas[]
  cargas_familiares      cargas_familiares[]
  compras_solicitadas    compras[]               @relation("oc_empleado")
  devoluciones           devoluciones[]
  departamento           departamentos           @relation(fields: [id_departamento], references: [id_departamento], map: "fk_emp_dpto")
  jefe                   empleados?              @relation("jefe_subordinado", fields: [id_jefe], references: [id_empleado], map: "fk_emp_jefe")
  subordinados           empleados[]             @relation("jefe_subordinado")
  rol                    roles                   @relation(fields: [id_rol], references: [id_rol], map: "fk_emp_rol")
  tipo_contrato          tipo_contrato?          @relation(fields: [id_tipo_contrato], references: [id_tipo_contrato], map: "fk_emp_tipo_contrato")
  entregas               entregas[]
  historial_cargo        historial_cargo[]       @relation("hca_empleado")
  historial_registrado   historial_cargo[]       @relation("hca_registrado")
  inventario_fisico      inventario_fisico[]
  inv_fisico_verificador inventario_fisico_det[] @relation("ivd_verificador")
  movimientos_inv        movimientos_inv[]
  rol_pagos              rol_pagos[]
  vendedor               vendedores?

  @@index([id_departamento, emp_sexo, emp_fecha_nacimiento], map: "idx_emp_ciudad_sexo_nacimiento")
  @@index([id_departamento, id_jefe, estado_emp], map: "idx_emp_dpto_jefe")
  @@index([id_departamento, emp_sueldo], map: "idx_emp_dpto_sueldo")
  @@schema("comercial")
}

model proveedores {
  id_proveedor       String               @id(map: "pk_proveedores") @db.Char(7)
  prv_nombre         String               @db.VarChar(40)
  prv_ruc_ced        String               @unique(map: "uq_prv_ruc_ced") @db.VarChar(13)
  prv_telefono       String?              @db.VarChar(10)
  prv_celular        String?              @db.VarChar(10)
  prv_mail           String?              @db.VarChar(60)
  id_ciudad          String               @db.Char(3)
  prv_direccion      String?              @db.VarChar(60)
  prv_tipo           String               @db.Char(3)
  estado_prv         String               @default("ACT") @db.Char(3)
  compras            compras[]
  proveedor_producto proveedor_producto[]
  ciudad             ciudades             @relation(fields: [id_ciudad], references: [id_ciudad], map: "fk_prv_ciudad")

  @@index([id_ciudad, estado_prv], map: "idx_prv_ciudad_estado")
  @@schema("comercial")
}

model proveedor_producto {
  id_proveedor String      @db.Char(7)
  id_producto  String      @db.Char(7)
  producto     productos   @relation(fields: [id_producto], references: [id_producto], onDelete: Cascade, map: "fk_pp_producto")
  proveedor    proveedores @relation(fields: [id_proveedor], references: [id_proveedor], onDelete: Cascade, map: "fk_pp_proveedor")

  @@id([id_proveedor, id_producto], map: "pk_proveedor_producto")
  @@schema("comercial")
}

model compras {
  id_compra        String         @id(map: "pk_compras") @db.Char(7)
  id_proveedor     String         @db.Char(7)
  id_descuento     String?        @db.Char(3)
  id_empleado      String         @db.Char(7)
  id_departamento  String         @db.Char(3)
  oc_fecha         DateTime       @default(now()) @db.Timestamp(6)
  oc_fecha_entrega DateTime       @db.Date
  oc_subtotal      Decimal        @default(0.00) @db.Decimal(10, 2)
  oc_iva           Decimal        @default(0.00) @db.Decimal(10, 2)
  oc_total         Decimal        @default(0.00) @db.Decimal(10, 2)
  estado_oc        String         @default("ABI") @db.Char(3)
  descuento        th_descuentos? @relation(fields: [id_descuento], references: [id_descuento], map: "fk_oc_descuento")
  departamento     departamentos  @relation(fields: [id_departamento], references: [id_departamento], map: "fk_oc_dpto")
  empleado         empleados      @relation("oc_empleado", fields: [id_empleado], references: [id_empleado], map: "fk_oc_empleado")
  proveedor        proveedores    @relation(fields: [id_proveedor], references: [id_proveedor], map: "fk_oc_proveedor")
  proxoc           proxoc[]
  recepciones      recepciones[]

  @@index([id_departamento, estado_oc], map: "idx_oc_departamento_estado")
  @@index([id_empleado, oc_fecha], map: "idx_oc_empleado_fecha")
  @@index([id_proveedor, estado_oc, oc_fecha(sort: Desc)], map: "idx_oc_proveedor_estado_fecha")
  @@schema("comercial")
}

model proxoc {
  id_compra    String    @db.Char(7)
  id_producto  String    @db.Char(7)
  pxo_cantidad Int       @default(1)
  pxo_valor    Decimal   @default(0.00) @db.Decimal(10, 2)
  pxo_subtotal Decimal   @default(0.00) @db.Decimal(10, 2)
  estado_pxoc  String    @default("ABI") @db.Char(3)
  compra       compras   @relation(fields: [id_compra], references: [id_compra], onDelete: Cascade, map: "fk_pxoc_compra")
  producto     productos @relation(fields: [id_producto], references: [id_producto], map: "fk_pxoc_producto")

  @@id([id_compra, id_producto], map: "pk_proxoc")
  @@index([id_producto, estado_pxoc], map: "idx_pxoc_producto_estado")
  @@schema("comercial")
}

model recepciones {
  id_recibo         String    @id(map: "pk_recepciones") @db.Char(7)
  id_compra         String    @db.Char(7)
  rec_descripcion   String?   @db.VarChar(60)
  rec_fecha_hora    DateTime  @default(now()) @db.Timestamp(6)
  rec_num_productos Int       @default(0)
  estado_rec        String    @default("PEN") @db.Char(3)
  proxrec           proxrec[]
  compra            compras   @relation(fields: [id_compra], references: [id_compra], map: "fk_rec_compra")

  @@index([id_compra, estado_rec], map: "idx_rec_compra_estado")
  @@schema("comercial")
}

model proxrec {
  id_recibo        String      @db.Char(7)
  id_producto      String      @db.Char(7)
  prx_cantidad     Int         @default(0)
  prx_qty_recibida Int         @default(0)
  estado_pxrec     String      @default("PEN") @db.Char(3)
  producto         productos   @relation(fields: [id_producto], references: [id_producto], map: "fk_pxrec_producto")
  recepcion        recepciones @relation(fields: [id_recibo], references: [id_recibo], onDelete: Cascade, map: "fk_pxrec_recibo")

  @@id([id_recibo, id_producto], map: "pk_proxrec")
  @@index([id_producto, estado_pxrec], map: "idx_pxrec_producto_estado")
  @@schema("comercial")
}

model tipo_cuenta {
  id_tipo_cta     String    @id(map: "pk_tipo_cuenta") @db.Char(3)
  tip_descripcion String    @db.VarChar(30)
  cuentas         cuentas[]

  @@schema("comercial")
}

model cuentas {
  id_cuenta       String      @id(map: "pk_cuentas") @db.Char(15)
  cue_descripcion String      @unique(map: "uq_cue_descripcion") @db.VarChar(60)
  cue_tipo        String      @db.Char(3)
  cue_debe00      Decimal     @default(0.00) @db.Decimal(12, 2)
  cue_debe01      Decimal     @default(0.00) @db.Decimal(12, 2)
  cue_debe02      Decimal     @default(0.00) @db.Decimal(12, 2)
  cue_debe03      Decimal     @default(0.00) @db.Decimal(12, 2)
  cue_debe04      Decimal     @default(0.00) @db.Decimal(12, 2)
  cue_debe11      Decimal     @default(0.00) @db.Decimal(12, 2)
  cue_debe12      Decimal     @default(0.00) @db.Decimal(12, 2)
  cue_debe13      Decimal     @default(0.00) @db.Decimal(12, 2)
  cue_haber00     Decimal     @default(0.00) @db.Decimal(12, 2)
  cue_haber01     Decimal     @default(0.00) @db.Decimal(12, 2)
  cue_haber02     Decimal     @default(0.00) @db.Decimal(12, 2)
  cue_haber03     Decimal     @default(0.00) @db.Decimal(12, 2)
  cue_haber10     Decimal     @default(0.00) @db.Decimal(12, 2)
  cue_haber11     Decimal     @default(0.00) @db.Decimal(12, 2)
  cue_haber12     Decimal     @default(0.00) @db.Decimal(12, 2)
  cue_haber13     Decimal     @default(0.00) @db.Decimal(12, 2)
  user_id         String?     @db.Char(16)
  estado_cue      String      @default("ACT") @db.Char(3)
  ctaxasi         ctaxasi[]
  tipo            tipo_cuenta @relation(fields: [cue_tipo], references: [id_tipo_cta], map: "fk_cue_tipo")

  @@schema("comercial")
}

model asientos {
  id_asiento      String         @id(map: "pk_asientos") @db.Char(7)
  asi_descripcion String         @db.VarChar(60)
  asi_total_debe  Decimal        @default(0.00) @db.Decimal(12, 2)
  asi_total_haber Decimal        @default(0.00) @db.Decimal(12, 2)
  asi_fecha_hora  DateTime       @default(now()) @db.Timestamp(6)
  user_id         String?        @db.Char(16)
  estado_asi      String         @default("PEN") @db.Char(3)
  ajustes_inv     ajustes_inv[]
  ctaxasi         ctaxasi[]
  devoluciones    devoluciones[]
  facturas        facturas[]
  rol_pagos       rol_pagos[]

  @@index([estado_asi, asi_fecha_hora(sort: Desc)], map: "idx_asi_estado_fecha")
  @@schema("comercial")
}

model ctaxasi {
  id_asiento String   @db.Char(7)
  id_cuenta  String   @db.Char(15)
  cxa_debe   Decimal  @default(0.00) @db.Decimal(12, 2)
  cxa_haber  Decimal  @default(0.00) @db.Decimal(12, 2)
  estado_cxa String   @default("ACT") @db.Char(3)
  asiento    asientos @relation(fields: [id_asiento], references: [id_asiento], onDelete: Cascade, map: "fk_cxa_asiento")
  cuenta     cuentas  @relation(fields: [id_cuenta], references: [id_cuenta], map: "fk_cxa_cuenta")

  @@id([id_asiento, id_cuenta], map: "pk_ctaxasi")
  @@index([id_cuenta, estado_cxa], map: "idx_cxa_cuenta_estado")
  @@schema("comercial")
}

model auditoria_sistema {
  id_auditoria   Int                @id(map: "pk_auditoria") @default(autoincrement())
  usuario_db     String             @db.VarChar(80)
  tabla_afectada String             @db.VarChar(30)
  operacion      tipo_operacion_dml
  id_registro    String             @db.VarChar(35)
  valor_anterior String?
  valor_nuevo    String?
  fecha_hora     DateTime           @default(now()) @db.Timestamp(6)
  ip_terminal    String?            @db.VarChar(45)

  @@index([tabla_afectada, fecha_hora(sort: Desc)], map: "idx_aud_tabla_fecha")
  @@index([usuario_db, operacion, fecha_hora(sort: Desc)], map: "idx_aud_usuario_operacion_fecha")
  @@schema("comercial")
}

model bodegas {
  id_bodega         String              @id(map: "pk_bodegas") @db.Char(3)
  bod_nombre        String              @unique(map: "uq_bod_nombre") @db.VarChar(60)
  bod_descripcion   String?             @db.VarChar(120)
  id_empleado       String              @db.Char(7)
  estado_bod        String              @default("ACT") @db.Char(3)
  ajustes_inv       ajustes_inv[]
  responsable       empleados           @relation(fields: [id_empleado], references: [id_empleado], map: "fk_bod_empleado")
  entregas          entregas[]
  inventario_fisico inventario_fisico[]
  movimientos_inv   movimientos_inv[]
  perchas           perchas[]
  stock_bodega      stock_bodega[]

  @@schema("comercial")
}

model perchas {
  id_percha             String                  @id(map: "pk_perchas") @db.Char(7)
  id_bodega             String                  @db.Char(3)
  per_letra             String                  @db.Char(1)
  per_numero            Int                     @db.SmallInt
  per_nivel             Int                     @db.SmallInt
  per_capacidad         Decimal                 @default(0) @db.Decimal(12, 4)
  estado_per            String                  @default("ACT") @db.Char(3)
  inventario_fisico_det inventario_fisico_det[]
  bodega                bodegas                 @relation(fields: [id_bodega], references: [id_bodega], map: "fk_per_bodega")
  ubicacion_percha      ubicacion_percha[]

  @@unique([id_bodega, per_letra, per_numero, per_nivel], map: "uq_per_ubicacion")
  @@index([id_bodega, per_letra, per_numero, per_nivel], map: "idx_per_bodega_ubicacion")
  @@schema("comercial")
}

model factor_conversion {
  id_producto     String    @id(map: "pk_factor_conversion") @db.Char(7)
  fac_factor      Decimal   @default(1.000000) @db.Decimal(14, 6)
  fac_descripcion String?   @db.VarChar(80)
  producto        productos @relation(fields: [id_producto], references: [id_producto], onDelete: Cascade, map: "fk_fac_producto")

  @@schema("comercial")
}

model ubicacion_percha {
  id_producto  String    @db.Char(7)
  id_percha    String    @db.Char(7)
  ubp_cantidad Decimal   @default(0) @db.Decimal(12, 4)
  percha       perchas   @relation(fields: [id_percha], references: [id_percha], map: "fk_ubp_percha")
  producto     productos @relation(fields: [id_producto], references: [id_producto], map: "fk_ubp_producto")

  @@id([id_producto, id_percha], map: "pk_ubicacion_percha")
  @@index([id_percha], map: "idx_ubp_percha")
  @@schema("comercial")
}

model stock_bodega {
  id_producto    String    @db.Char(7)
  id_bodega      String    @db.Char(3)
  stk_cantidad   Decimal   @default(0) @db.Decimal(12, 4)
  stk_reservado  Decimal   @default(0) @db.Decimal(12, 4)
  stk_disponible Decimal?  @default(dbgenerated("(stk_cantidad - stk_reservado)")) @db.Decimal(12, 4)
  stk_costo_prom Decimal   @default(0) @db.Decimal(14, 6)
  stk_ultima_act DateTime  @default(now()) @db.Timestamp(6)
  bodega         bodegas   @relation(fields: [id_bodega], references: [id_bodega], map: "fk_stk_bodega")
  producto       productos @relation(fields: [id_producto], references: [id_producto], map: "fk_stk_producto")

  @@id([id_producto, id_bodega], map: "pk_stock_bodega")
  @@index([id_bodega, stk_cantidad], map: "idx_stk_bodega")
  @@schema("comercial")
}

model ajustes_inv {
  id_ajuste       String           @id(map: "pk_ajustes_inv") @db.Char(7)
  id_bodega       String           @db.Char(3)
  id_empleado     String           @db.Char(7)
  id_aprobador    String?          @db.Char(7)
  id_asiento      String?          @db.Char(7)
  aji_motivo      String           @db.VarChar(200)
  aji_fecha       DateTime         @default(now()) @db.Timestamp(6)
  aji_fecha_apr   DateTime?        @db.Timestamp(6)
  aji_num_prod    Int              @default(0)
  aji_total       Decimal          @default(0.00) @db.Decimal(14, 2)
  aji_observacion String?          @db.VarChar(300)
  estado_aji      String           @default("ABI") @db.Char(3)
  detalle         ajuste_inv_det[]
  aprobador       empleados?       @relation("aji_aprobador", fields: [id_aprobador], references: [id_empleado], onDelete: Restrict, map: "fk_aji_aprobador")
  asiento         asientos?        @relation(fields: [id_asiento], references: [id_asiento], onDelete: Restrict, map: "fk_aji_asiento")
  bodega          bodegas          @relation(fields: [id_bodega], references: [id_bodega], map: "fk_aji_bodega")
