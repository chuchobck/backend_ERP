  id_carga             String    @id(map: "pk_cargas_familiares") @db.Char(7)
  id_empleado          String    @db.Char(7)
  car_cedula           String?   @db.VarChar(13)
  car_apellidos        String    @db.VarChar(60)
  car_nombres          String    @db.VarChar(60)
  car_fecha_nacimiento DateTime  @db.Date
  car_sexo             String    @db.Char(1)
  car_parentesco       String    @db.Char(3)
  car_estado_civil     String?   @db.Char(3)
  car_es_dependiente   Boolean   @default(true)
  estado_car           String    @default("ACT") @db.Char(3)
  empleado             empleados @relation(fields: [id_empleado], references: [id_empleado], map: "fk_car_empleado")

  @@index([id_empleado, car_parentesco, car_fecha_nacimiento], map: "idx_car_empleado_parentesco_nacimiento")
  @@index([car_parentesco, car_sexo, estado_car], map: "idx_car_parentesco_sexo_estado")
  @@schema("comercial")
}

model historial_cargo {
  id_historial                                                  BigInt         @id(map: "pk_historial_cargo") @default(autoincrement())
  id_empleado                                                   String         @db.Char(7)
  hca_tipo                                                      String         @db.Char(3)
  id_rol_anterior                                               String?        @db.Char(3)
  id_rol_nuevo                                                  String         @db.Char(3)
  id_dpto_anterior                                              String?        @db.Char(3)
  id_dpto_nuevo                                                 String         @db.Char(3)
  hca_sueldo_anterior                                           Decimal        @default(0.00) @db.Decimal(14, 2)
  hca_sueldo_nuevo                                              Decimal        @default(0.00) @db.Decimal(14, 2)
  hca_incremento                                                Decimal?       @default(dbgenerated("(hca_sueldo_nuevo - hca_sueldo_anterior)")) @db.Decimal(14, 2)
  hca_fecha                                                     DateTime       @db.Date
  hca_motivo                                                    String?        @db.VarChar(200)
  hca_registrado_por                                            String?        @db.Char(7)
  departamentos_historial_cargo_id_dpto_anteriorTodepartamentos departamentos? @relation("historial_cargo_id_dpto_anteriorTodepartamentos", fields: [id_dpto_anterior], references: [id_departamento], onDelete: Restrict, map: "fk_hca_dpto_anterior")
  departamentos_historial_cargo_id_dpto_nuevoTodepartamentos    departamentos  @relation("historial_cargo_id_dpto_nuevoTodepartamentos", fields: [id_dpto_nuevo], references: [id_departamento], map: "fk_hca_dpto_nuevo")
  empleado                                                      empleados      @relation("hca_empleado", fields: [id_empleado], references: [id_empleado], map: "fk_hca_empleado")
  registrador                                                   empleados?     @relation("hca_registrado", fields: [hca_registrado_por], references: [id_empleado], onDelete: Restrict, map: "fk_hca_registrado_por")
  rol_anterior                                                  roles?         @relation("rol_anterior", fields: [id_rol_anterior], references: [id_rol], onDelete: Restrict, map: "fk_hca_rol_anterior")
  rol_nuevo                                                     roles          @relation("rol_nuevo", fields: [id_rol_nuevo], references: [id_rol], map: "fk_hca_rol_nuevo")

  @@index([id_empleado, hca_fecha(sort: Desc)], map: "idx_hca_empleado_fecha")
  @@index([hca_tipo, hca_fecha(sort: Desc)], map: "idx_hca_tipo_fecha")
  @@schema("comercial")
}

model asistencias {
  id_asistencia    BigInt    @id(map: "pk_asistencias") @default(autoincrement())
  id_empleado      String    @db.Char(7)
  asi_fecha        DateTime  @db.Date
  asi_tipo         String    @default("PRE") @db.Char(3)
  asi_hora_entrada DateTime? @db.Time(6)
  asi_hora_salida  DateTime? @db.Time(6)
  asi_justificada  Boolean   @default(false)
  asi_observacion  String?   @db.VarChar(200)
  empleado         empleados @relation(fields: [id_empleado], references: [id_empleado], map: "fk_asi_empleado")

  @@unique([id_empleado, asi_fecha], map: "uq_asistencia_emp_fecha")
  @@index([id_empleado, asi_tipo, asi_fecha(sort: Desc)], map: "idx_asi_empleado_tipo_fecha")
  @@index([asi_fecha(sort: Desc), asi_tipo, asi_justificada], map: "idx_asi_fecha_tipo_justificada")
  @@schema("comercial")
}

enum tipo_operacion_dml {
  INSERT
  UPDATE
  DELETE

  @@schema("comercial")
}
